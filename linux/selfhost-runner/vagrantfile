Vagrant.configure("2") do |config|
  servers = [
    {
      :hostname => "Server1",
      :box =>  "bento/rockylinux-9",
      :box_version => "202510.26.0",
      :ip => "192.168.56.150" # Changed to match VMware standard subnet
    }
  ]

  servers.each do |machine|
    config.vm.define machine[:hostname] do |node|
      node.vm.box = machine[:box]
      node.vm.box_version = machine[:box_version]
      node.vm.box_architecture = "arm64"
      node.vm.hostname = machine[:hostname]
      
      # Private network on a unified subnet
      node.vm.network :private_network, ip: machine[:ip]

      # We removed the manual "forwarded_port" line to let Vagrant handle SSH natively

      node.vm.provider :virtualbox do |vb|
        vb.customize ["modifyvm", :id, "--memory", 512]
        vb.customize ["modifyvm", :id, "--cpus", 1]
        
        # Open the GUI window so you can see what's happening during boot.
        # You can change this to false once everything works flawlessly.
        vb.gui = true 
      end
      
      # https://developer.hashicorp.com/vagrant/docs/provisioning/shell#external-script
      node.vm.provision "shell" do |ps|
        ps.privileged = true
        ps.path = "scripts/installRunnerArm.sh"
      end

      node.vm.provision "shell" do |ps|
        ps.privileged = true
        ps.path = "scripts/installDocker.sh"
      end

      node.vm.provision "shell" do |ps|
        ps.privileged = true
        ps.path = "scripts/configureDNSResolver.sh"
      end

      # https://developer.hashicorp.com/vagrant/docs/networking/forwarded_ports
      # Need to port map 80:80 tcp, 3306:3306 tcp for 2tier
      node.vm.network "forwarded_port", guest: 80, host: 80, protocol: "tcp"
      node.vm.network "forwarded_port", guest: 3306, host: 3306, protocol: "tcp"

      # Need to port map 53:53 udp, 53:53 tcp, 953:953/tcp for dns
      # node.vm.network "forwarded_port", guest: 53, host: 53, protocol: "udp"
      # node.vm.network "forwarded_port", guest: 53, host: 53, protocol: "tcp"
      # node.vm.network "forwarded_port", guest: 953, host: 953, protocol: "tcp"
    end
  end
end